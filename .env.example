# barq-vault Environment Variables
# Copy this to .env and fill in your values

# Server
BARQ_SERVER__GRPC_ADDR=0.0.0.0:50051
BARQ_SERVER__REST_ADDR=0.0.0.0:8080
BARQ_SERVER__STORE_PATH=./data
BARQ_SERVER__MAX_PAYLOAD_BYTES=104857600

# TLS
BARQ_SERVER__TLS__ENABLED=false
BARQ_SERVER__TLS__CERT_PATH=
BARQ_SERVER__TLS__KEY_PATH=

# Auth
BARQ_SERVER__AUTH__ENABLED=false
BARQ_SERVER__AUTH__TOKEN=

# LLM Provider
BARQ_LLM_PROVIDER=openai
BARQ_LLM_KEY=
BARQ_LLM_MODEL=gpt-4o-mini
BARQ_LLM_BASE_URL=

# Embedding Provider
BARQ_EMBED_PROVIDER=openai
BARQ_EMBED_KEY=
BARQ_EMBED_MODEL=text-embedding-3-small
BARQ_EMBED_BASE_URL=

# STT Provider
BARQ_STT_PROVIDER=openai
BARQ_STT_KEY=
BARQ_STT_MODEL=whisper-1
BARQ_WHISPER_BIN_PATH=

# VLM Provider
BARQ_VLM_PROVIDER=openai
BARQ_VLM_KEY=
BARQ_VLM_MODEL=gpt-4o
BARQ_VLM_BASE_URL=

# Environment
BARQ_ENV=development
